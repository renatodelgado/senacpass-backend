# Aplicação
NODE_ENV=development
PORT=3333

# PostgreSQL
# Valores compatíveis com o docker-compose.yml do projeto.
DB_HOST=localhost
DB_PORT=5433
DB_USER=admin
DB_PASSWORD=troque-esta-senha
DB_NAME=api_db

# Autenticação
# Use uma chave longa, aleatória e diferente em cada ambiente.
JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria

# Variáveis reservadas para uso futuro.
# Atualmente não são consumidas pelo backend.
# JWT_EXPIRES_IN=1d
# SENTRY_DSN=
# BASE_URL=http://localhost:3333
# ML_BASE_URL=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
